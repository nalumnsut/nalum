# Environment
NODE_ENV=

# Server (ignored under Docker — see SETUP.md)
PORT=

# Frontend URL (for email links; ignored under Docker — see SETUP.md)
FRONTEND_URL=

# MongoDB (ignored under Docker — see SETUP.md)
MONGODB_URI=

# Debug mode for email testing (set to "true" to log verification links in console)
DEBUG_MAIL=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=

# Mail (works but move to App Password later)
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=

BREVO_SMTP_USER=

MAIL_FROM_NAME=
MAIL_FROM_EMAIL=

BREVO_SMTP_PASS=

# PostgreSQL — optional outside production, see SETUP.md's Postgres section
POSTGRESQL_DATABASE_URL=

# Web Push (VAPID) Keys - Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Redis URL (ignored under Docker — see SETUP.md)
REDIS_URL=
